# Core app
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
MATTERPORT_PLATFORM_API_URL=http://127.0.0.1:8000
MATTERPORT_CONTENT_BACKEND=auto

# Matterport embed access
NEXT_PUBLIC_MATTERPORT_MODEL_SID=
NEXT_PUBLIC_MATTERPORT_SDK_KEY=

# Sanity Studio / CRM provider
SANITY_PROJECT_ID=
SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Matterport server-side APIs
MATTERPORT_API_TOKEN_ID=
MATTERPORT_API_TOKEN_SECRET=
MATTERPORT_WEBHOOK_SECRET=

# Matterport OAuth for private-model embeds (only if enabled on your account)
MATTERPORT_OAUTH_CLIENT_ID=
MATTERPORT_OAUTH_CLIENT_SECRET=
MATTERPORT_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/matterport/callback

# AI providers
OPENAI_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
MINIMAX_API_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_TEXT_MODEL=MiniMax-M1
MINIMAX_TIMEOUT_SECONDS=30
MINIMAX_VISION_TIMEOUT_SECONDS=45

# Data layer
DATABASE_URL=
REDIS_URL=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
