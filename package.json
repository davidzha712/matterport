{
  "name": "matterport-platform",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <22 || >=22.12.0"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "audit:op:missing-login-metadata": "node scripts/op-audit-login-metadata.mjs",
    "dev:web": "npm --workspace @matterport/web run dev",
    "build:web": "npm --workspace @matterport/web run build",
    "lint:web": "npm --workspace @matterport/web run lint",
    "test:op:audit": "node --test scripts/op-audit-login-metadata.test.mjs",
    "typecheck:web": "npm --workspace @matterport/web run typecheck",
    "test:web": "npm --workspace @matterport/web run test",
    "test:e2e:web": "npm --workspace @matterport/web run test:e2e"
  }
}
